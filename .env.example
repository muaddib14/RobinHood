# Server-side only — never prefix with NEXT_PUBLIC_.

# Arkham Intel API — https://arkm.com (Settings -> API Keys)
ARKHAM_API_KEY=

# Solana RPC — Helius free tier is enough for a single-user deploy
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# OpenRouter — verdict synthesis (Ministral, cheap/light model, single-user use)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/ministral-8b

# Optional — arms live Exit Watch alerts via Arkham's own alerting infra.
# Create an alert method first in the Arkham dashboard, then paste its numeric ID.
# Leave unset to skip Exit Watch entirely (scan still works without it).
ARKHAM_ALERT_METHOD_ID=
