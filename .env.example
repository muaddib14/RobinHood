# Server-side only — never prefix with NEXT_PUBLIC_.

# RugCheck.xyz token-report API — free, public, NO KEY REQUIRED.
# Covers deployer, mint/freeze authority, LP lock, holder concentration.
# Nothing to configure here; scan works out of the box for token mints.

# Arkham Intel API — OPTIONAL, paid plan (or trial). Adds entity graph,
# funding trace, Arkham risk score, smart-money, exit-watch alerts on top
# of RugCheck. Scan works fully without this — https://arkm.com (Settings -> API Keys)
ARKHAM_API_KEY=

# Solana RPC — Helius free tier is enough for a single-user deploy
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# OpenRouter — verdict synthesis (Ministral, cheap/light model, single-user use)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/ministral-8b-2512

# Optional — arms live Exit Watch alerts via Arkham's own alerting infra.
# Create an alert method first in the Arkham dashboard, then paste its numeric ID.
# Leave unset to skip Exit Watch entirely (scan still works without it).
ARKHAM_ALERT_METHOD_ID=

# Neon Postgres — scan cache (M2) + future users/watchlist/alerts (M3).
# console.neon.tech -> project -> Connection Details -> pooled connection string.
DATABASE_URL=
